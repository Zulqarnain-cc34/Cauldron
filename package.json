{
  "name": "cauldron",
  "version": "0.1.0",
  "description": "Layered falling-sand simulation library with plugin SDK",
  "type": "module",
  "exports": {
    ".": "./js/cauldron/index.js",
    "./plugin": "./js/cauldron/plugin.js",
    "./extend": "./js/cauldron/extend.js",
    "./app": "./js/cauldron/app.js",
    "./worldgen": "./js/cauldron/worldgen.js",
    "./tooling": "./js/cauldron/tooling.js",
    "./bootstrap": "./js/cauldron/bootstrap.js"
  },
  "scripts": {
    "start": "npx --yes serve . -p 3456",
    "dev": "npm start",
    "build": "node tooling/scripts/build.mjs",
    "test": "node --test tooling/tests/run-node.js",
    "test:watch": "node tooling/scripts/test-watch.mjs",
    "test:visual": "npm start",
    "verify": "npm run build && npm test && npm run check:layers && npm run check:behaviors && npm run check:coverage && npm run check:snapshots",
    "release": "node tooling/scripts/release-check.mjs",
    "check:layers": "node tooling/scripts/check-layers.mjs",
    "check:behaviors": "node tooling/scripts/check-behaviors.mjs",
    "check:coverage": "node tooling/scripts/check-coverage.mjs",
    "check:snapshots": "node tooling/scripts/behavior-snapshot.mjs",
    "snapshot:update": "node tooling/scripts/behavior-snapshot.mjs --write",
    "export:verification": "node tooling/scripts/export-verification.mjs",
    "export:verification:quick": "node tooling/scripts/export-verification.mjs --quick",
    "copy:llm": "bash tooling/scripts/copy-llm.sh",
    "setup:hooks": "bash tooling/scripts/install-hooks.sh"
  }
}
